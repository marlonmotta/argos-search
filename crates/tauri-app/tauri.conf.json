{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Argos Search",
  "version": "0.4.0",
  "identifier": "dev.hell.argos-search",
  "build": {
    "frontendDist": "../frontend",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Argos Search",
        "label": "main",
        "width": 800,
        "height": 600,
        "minWidth": 520,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      },
      {
        "title": "Argos Launcher",
        "label": "launcher",
        "url": "/launcher.html",
        "width": 640,
        "height": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
